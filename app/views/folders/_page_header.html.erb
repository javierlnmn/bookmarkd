<%= render "folders/navigation" %>

<div class="flex flex-col sm:flex-row sm:items-start justify-between gap-4 mb-8">
  <div class="flex flex-col gap-2">
    <div class="flex items-center gap-2" id="folder-title-container">
      <% if !@folder.nil? and @folder.is_public %>
        <svg class="size-8 min-w-8 text-blue-600 group-hover:text-blue-400 transition-colors" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24" title="Public folder">
          <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
          <path d="M3 12a9 9 0 1 0 18 0a9 9 0 0 0 -18 0" />
          <path d="M3.6 9h16.8" />
          <path d="M3.6 15h16.8" />
          <path d="M11.5 3a17 17 0 0 0 0 18" />
          <path d="M12.5 3a17 17 0 0 1 0 18" />
        </svg>
      <% end %>
      <% if @folder && @folder.owned_by?(Current.user) && @folder.collaborative_scope? %>
        <%= render partial: "folder_collaborations/collaborator_icon" %>
      <% end %>
      <h1 id="folder-title" class="text-3xl font-bold text-white"><%= title %></h1>
    </div>    
    <p class="text-zinc-500 text-sm font-medium"><%= subtitle %></p>
  </div>

  <div class="flex gap-2 items-center">
    <div data-controller="dropdown" class="relative">
      <% if !@folder || @folder.is_owner_or_collaborator?(Current.user) %>
        <button data-action="dropdown#toggle" data-dropdown-target="button" class="h-11 min-w-40 inline-flex items-center justify-center gap-2 px-5 bg-zinc-100 hover:bg-white text-zinc-950 font-bold rounded-xl transition-all active:scale-95 shadow-lg shadow-white/5 cursor-pointer">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          Add New
        </button>
      <% end %>

      <div data-dropdown-target="list" class="hidden absolute top-[calc(100%+8px)] right-0 max-sm:left-0 max-sm:right-auto  w-48 bg-zinc-900 border border-zinc-800 rounded-2xl p-2 shadow-2xl z-50 animate-in fade-in zoom-in duration-200">
        <%= link_to bookmark_path,
            data: { turbo_frame: 'modal', action: "click->dropdown#hide" },
            class: "flex items-center gap-3 px-4 py-3 text-zinc-300 hover:text-white hover:bg-zinc-800 rounded-xl transition-colors text-sm font-semibold group" do %>
          <svg class="w-4 h-4 text-zinc-500 group-hover:text-orange-400 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/></svg>
          New Bookmark
        <% end %>

        <%= link_to folder_path,
            data: { turbo_frame: 'modal', action: "click->dropdown#hide" },
            class: "flex items-center gap-3 px-4 py-3 text-zinc-300 hover:text-white hover:bg-zinc-800 rounded-xl transition-colors text-sm font-semibold group" do %>
          <svg class="w-4 h-4 text-zinc-500 group-hover:text-blue-400 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/></svg>
          New Folder
        <% end %>
      </div>
    </div>

    <% if @folder && @folder.owned_by?(Current.user) %>
      <%= link_to new_folder_folder_collaboration_path(@folder), data: { turbo_frame: 'modal' }, title: "Add collaborator", class: "h-11 w-11 inline-flex items-center justify-center bg-zinc-800/50 hover:bg-zinc-700 text-zinc-400 hover:text-white rounded-xl transition-all active:scale-90" do %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
          <path d="M9 7a4 4 0 1 0 0 8a4 4 0 0 0 0 -8z"/>
          <path d="M3 21v-2a4 4 0 0 1 4 -4h4a4 4 0 0 1 4 4v2"/>
          <path d="M16 11h6m-3 -3v6"/>
        </svg>
      <% end %>
    <% end %>
  </div>
</div>
