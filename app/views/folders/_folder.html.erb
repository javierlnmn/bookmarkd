<div
  id="<%= dom_id folder %>"
  class="group relative bg-zinc-900/40 hover:bg-zinc-900/80 border border-zinc-800 hover:border-zinc-700 p-5 rounded-2xl transition-all duration-300"
  data-bookmarks-filters-target="folder"
>
  <div class="h-full flex flex-col gap-4">
    <div class="flex items-start justify-between gap-4">
      <div class="flex-1 min-w-0">
        <%= link_to folder_path(folder), class: "block group" do %>
          <h3 class="font-bold text-zinc-100 group-hover:text-blue-400 transition-colors flex items-center gap-2">
            <% if folder.is_public? %>
              <svg class="size-5 min-w-5 text-blue-600 group-hover:text-blue-400 transition-colors" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24" title="Public folder">
                <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                <path d="M3 12a9 9 0 1 0 18 0a9 9 0 0 0 -18 0" />
                <path d="M3.6 9h16.8" />
                <path d="M3.6 15h16.8" />
                <path d="M11.5 3a17 17 0 0 0 0 18" />
                <path d="M12.5 3a17 17 0 0 1 0 18" />
              </svg>
            <% else %>
              <svg class="size-5 min-w-5 self-start text-zinc-500 group-hover:text-blue-400 transition-colors" fill="currentColor" viewBox="0 0 20 20">
                <path d="M2 6a2 2 0 012-2h5l2 2h5a2 2 0 012 2v6a2 2 0 01-2 2H4a2 2 0 01-2-2V6z"/>
              </svg>
            <% end %>
            <%= folder.name %>
          </h3>
          <p class="text-xs font-medium text-zinc-500 truncate mt-1">
            <%= folder.description.presence || "No description" %>
          </p>
        <% end %>
      </div>
      
      <div class="flex items-center gap-2">
        <% if folder.editable_by?(Current.user) %>
          <%= link_to move_folder_form_path(folder), data: { turbo_frame: 'modal' }, class: "p-2.5 bg-zinc-800/50 text-zinc-400 hover:text-white hover:bg-zinc-700 rounded-xl transition-all active:scale-90", title: "Move to folder" do %>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
              <path d="M12 19H5a2 2 0 01-2-2V6a2 2 0 012-2h4l2 2h2"/>
              <path d="M19 16l3-3-3-3"/>
              <path d="M22 13H13"/>
            </svg>
          <% end %>
        <% end %>
        <%= link_to folder_path(folder), class: "p-2.5 bg-zinc-800/50 text-zinc-400 hover:text-white hover:bg-zinc-700 rounded-xl transition-all active:scale-90" do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        <% end %>
      </div>
    </div>

    <div class="mt-auto flex items-center gap-2">
      <span class="text-[10px] font-bold uppercase tracking-widest text-zinc-500 bg-zinc-800/30 px-2.5 py-1 rounded-lg border border-zinc-800/50">
        <%= pluralize(folder.children.count + folder.bookmarks.count, 'item') %>
      </span>

      <div class="ml-auto flex gap-1 items-center">
        <% if folder.editable_by?(Current.user) %>
          <%= link_to edit_folder_path(folder), data: { turbo_frame: 'modal' }, class: "p-2 text-zinc-500 hover:text-zinc-100 hover:bg-zinc-800 rounded-xl transition-all active:scale-90 cursor-pointer", title: "Edit" do %>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/>
            </svg>
          <% end %>
          
          <%= button_to folder_path(folder), method: :delete,  data: { turbo_confirm: "Are you sure about that?" }, class: "p-2 text-zinc-500 hover:text-red-400 hover:bg-red-500/10 rounded-xl transition-all active:scale-90 cursor-pointer" do %>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>
</div>