<div class="flex flex-col gap-4" data-controller="bookmarks-filters">
  <% if folders.length > 0 || bookmarks.length > 0 %>
    <%= render "folders/filters" %>
  <% end %>

  <div id="folders-container" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
  <% if folders.length > 0 %>
    <% folders.each do |folder| %>
      <%= render "folders/folder", folder: folder %>
    <% end %>
  <% else %>
    <div id="folders-empty" class="col-span-full">
      <div class="flex items-center gap-3 rounded-2xl border border-dashed border-zinc-800 bg-zinc-900/20 px-5 py-6 text-zinc-500">
        <svg class="size-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/></svg>
        <p class="text-sm font-medium">No folders yet. Folders you create will show up here.</p>
      </div>
    </div>
  <% end %>
  </div>

  <span class="w-full h-px bg-zinc-800/30"></span>

  <div
    id="bookmarks-container"
    class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4"
  >
    <% if bookmarks.length > 0 %>
      <% bookmarks.each do |bookmark| %>
        <%= render "bookmarks/bookmark", bookmark: bookmark %>
      <% end %>
    <% else %>
      <div id="bookmarks-empty" class="col-span-full">
        <div class="flex items-center gap-3 rounded-2xl border border-dashed border-zinc-800 bg-zinc-900/20 px-5 py-6 text-zinc-500">
          <svg class="size-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/></svg>
          <p class="text-sm font-medium">No bookmarks yet. Bookmarks you save will show up here.</p>
        </div>
      </div>
    <% end %>
  </div>
</div>
