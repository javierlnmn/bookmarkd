<div class="flex flex-col sm:flex-row gap-3 mb-6">
  <div class="relative flex-1">
    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
      <svg class="w-4 h-4 text-zinc-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
      </svg>
    </div>
    <input
      data-bookmarks-filters-target="searchbar"
      data-action="input->bookmarks-filters#searchbar"
      type="text"
      placeholder="Search folders or bookmarks..."
      class="w-full pl-10 pr-4 py-2.5 bg-zinc-900/40 border border-zinc-800 hover:border-zinc-700 focus:border-orange-500/50 focus:ring-1 focus:ring-orange-500/20 rounded-xl text-sm text-zinc-100 placeholder-zinc-500 transition-all outline-none"
    />
  </div>

  <div class="relative flex justify-end" data-controller="dropdown">
    <button
      type="button"
      data-action="click->dropdown#toggle"
      class="flex items-center gap-2 px-4 py-2.5 bg-zinc-900/40 border border-zinc-800 hover:border-zinc-700 rounded-xl text-sm text-zinc-400 hover:text-zinc-100 transition-all cursor-pointer"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/>
      </svg>
      <span>Filter by tags</span>
      <svg class="w-3 h-3 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
      </svg>
    </button>

    <div data-dropdown-target="list" class="hidden absolute right-0 top-full mt-2 min-w-[200px] p-2 bg-zinc-800 border border-zinc-700 rounded-xl shadow-xl z-50">
      <p class="text-[10px] font-bold uppercase tracking-widest text-zinc-500 px-2 mb-2">Select tags</p>
      <div id="tags-filter_container" class="flex flex-col gap-1 max-h-48 overflow-y-auto">
        <% if Current.user.present? %>
          <%= render partial: "tags/filter_tag", collection: Current.user.tags, as: :tag %>
        <% end %>
      </div>
      <div class="border-t border-zinc-700 mt-2 pt-2">
        <button
          type="button"
          class="cursor-pointer w-full px-3 py-1.5 text-xs font-medium text-zinc-400 hover:text-zinc-100 hover:bg-zinc-700/50 rounded-lg transition-colors"
          data-action="click->bookmarks-filters#tagsReset"
        >
          Clear filters
        </button>
      </div>
    </div>
  </div>
</div>
