<button type="button" id="<%= dom_id bookmark %>-tags-button" data-action="click->dropdown#toggle" class="size-7 text-base font-bold uppercase tracking-widest text-zinc-400 hover:text-zinc-300 transition-colors bg-zinc-800/30 rounded-lg border border-zinc-800/50 flex items-center justify-center cursor-pointer">
  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
</button>

<div data-dropdown-target="list" class="hidden absolute left-0 top-full mt-1 min-w-[140px] py-1 bg-zinc-800 border border-zinc-700 rounded-xl shadow-xl z-50">
  <div id="<%= dom_id bookmark %>-tags_container" class="flex flex-col gap-2 p-2 max-h-70 overflow-scroll" data-tag-choices-container="true">
    <% tags = Current.user.tags %>
    <% tags.order(:name).each do |tag| %>
      <%= render "tags/simple_tag", bookmark: bookmark, tag: tag, tag_being_used: bookmark.tags.include?(tag) %>
    <% end %>
    <% if tags.none? %>
      <%= render "tags/no_tags_message_bookmark", bookmark: bookmark %>
    <% end %>
  </div>

  <div class="border-t border-zinc-700 mt-1 pt-1 px-1">
    <%= link_to profile_path(tab: "tags"), title: "Manage tags", class: "flex items-center gap-2 px-2 py-1.5 rounded-lg text-xs font-medium text-zinc-400 hover:text-zinc-100 hover:bg-zinc-700/50 transition-colors" do %>
      <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
      </svg>
      Manage tags
    <% end %>
  </div>
</div>
