<%= turbo_stream.remove_all "[id='#{dom_id(@tag)}-simple_tag-container']" %>
<%= turbo_stream.remove_all "[id$='#{dom_id(@tag)}-bookmark_tag']" %>
<%= turbo_stream.remove_all "[id$='#{dom_id(@tag)}-filter_tag']" %>
<%= turbo_stream.remove_all "[id$='#{dom_id(@tag)}-form_tag']" %>

<% if Current.user.tags.reload.none? %>
  <%= turbo_stream.append "tags-form_container", partial: "tags/no_tags_message_form" %>

  <% Current.user.editable_bookmarks.each do |bookmark| %>
    <%= turbo_stream.append "#{dom_id(bookmark)}-tags_container", partial: "tags/no_tags_message_bookmark", locals: { bookmark: bookmark } %>
  <% end %>
<% end %>
