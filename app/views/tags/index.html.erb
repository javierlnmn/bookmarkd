<% content_for :modal_size do %>max-w-2xl max-h-[85vh] overflow-y-auto<% end %>
<% content_for :modal_header do %>
  <h2 class="text-lg font-bold text-zinc-100">Tags</h2>
<% end %>

<% content_for :modal_content do %>
  <div class="space-y-4">
    <%= render "form", tag: @tag %>

    <div class="space-y-1">
      <p class="text-[10px] font-bold uppercase tracking-widest text-zinc-500 ml-1 mb-2">Your tags</p>
      <div id="tags-form_container" class="flex flex-wrap gap-2 overflow-y-auto pr-1 -mr-1 max-h-96">
        <% if @tags.any? %>
            <%= render partial: 'form_tag', collection: @tags, as: :tag %>
        <% else %>
          <%= render "no_tags_message_form" %>
        <% end %>
      </div>
    </div>
  </div>
<% end %>
