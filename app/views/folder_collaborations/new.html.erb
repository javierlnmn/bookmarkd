<% content_for :modal_size do %>max-w-lg<% end %>
<% content_for :modal_header do %>
  <h2 class="text-lg font-bold text-white">Collaborators</h2>
<% end %>

<% content_for :modal_content do %>
  <div class="space-y-4">
    <%= render "form" %>

    <% inherited_collaborators = @folder.inherited_collaborators %>
    <% if inherited_collaborators.any? %>
      <div class="space-y-1">
        <p class="text-[10px] font-bold uppercase tracking-widest text-zinc-500 ml-1 mb-2">Inherited from parent folders</p>
        <div class="flex flex-wrap gap-2">
          <% inherited_collaborators.each do |user| %>
            <div class="h-7 inline-flex items-center gap-2 py-px px-2 rounded-lg bg-zinc-800/30 border border-dashed border-zinc-700 w-fit shrink-0" title="Inherited from a parent folder">
              <svg class="w-3 h-3 text-zinc-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/>
              </svg>
              <span class="text-xs font-medium text-zinc-400 truncate"><%= user.email_address %></span>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <div class="space-y-1">
      <p class="text-[10px] font-bold uppercase tracking-widest text-zinc-500 ml-1 mb-2">Current collaborators</p>
      <div id="<%= dom_id(@folder) %>-collaborators_container" class="flex flex-wrap gap-2 overflow-y-auto pr-1 -mr-1 max-h-60">
        <% if @folder.folder_collaborations.any? %>
          <% @folder.folder_collaborations.each do |folder_collaboration| %>
            <div id="<%= dom_id folder_collaboration %>" class="h-7 inline-flex items-center gap-2 py-px px-2 rounded-lg bg-zinc-800/60 border border-zinc-700 w-fit shrink-0">
              <span class="text-xs font-semibold text-zinc-300 truncate"><%= folder_collaboration.user.email_address %></span>

              <%= button_to folder_folder_collaboration_path(folder_collaboration.folder, folder_collaboration),
                  method: :delete,
                  data: { turbo_confirm: "Remove this collaborator?" },
                  class: "p-0.5 text-zinc-400 cursor-pointer hover:text-red-400 hover:bg-red-500/20 rounded-lg transition-colors" do %>
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
              <% end %>
            </div>
          <% end %>
        <% else %>
          <%= render "folder_collaborations/empty", folder: @folder %>
        <% end %>
      </div>
    </div>
  </div>
<% end %>
