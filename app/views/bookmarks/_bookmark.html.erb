<div
  id="<%= dom_id bookmark %>"
  class="group relative bg-zinc-900/40 hover:bg-zinc-900/80 border border-zinc-800 hover:border-zinc-700 p-5 rounded-2xl transition-all duration-300"
  data-bookmarks-filters-target="bookmark"
>
  <div class="flex flex-col gap-4 h-full">
    <div class="relative overflow-hidden rounded-xl rounded-b-none -mx-5 -mt-5 mb-2 min-h-[120px]">
      <% if bookmark.thumbnail.present? %>
        <div class="absolute inset-0 z-0">
          <img 
            src="<%= bookmark.thumbnail %>" 
            alt="<%= bookmark.name %> thumbnail"
            class="w-full h-full object-cover opacity-50 transition-opacity duration-300 group-hover:opacity-60"
            loading="lazy"
            onerror="this.parentElement.style.display='none'"
          />
          <div class="absolute inset-0 bg-gradient-to-b from-zinc-950/60 via-zinc-950/50 to-zinc-950/70"></div>
        </div>
      <% else %>
        <div class="absolute inset-0 bg-gradient-to-br from-zinc-900/60 via-zinc-800/50 to-zinc-900/70">
          <div class="absolute inset-0 opacity-10" style="background-image: repeating-linear-gradient(45deg, transparent, transparent 10px, rgba(255,255,255,0.1) 10px, rgba(255,255,255,0.1) 20px);"></div>
          <div class="absolute inset-0 flex items-center justify-center opacity-20">
            <svg class="w-24 h-24 text-orange-500/30" fill="currentColor" stroke="none" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z"/>
            </svg>
          </div>
        </div>
      <% end %>
      
      <div class="relative z-10 flex items-start justify-between gap-4 p-5">
        <div class="flex-1 min-w-0 flex flex-col gap-1">
          <h3 class="font-bold text-zinc-100 group-hover:text-orange-400 transition-colors flex items-center gap-2">
            <svg class="mt-1 size-4 min-w-4 self-start text-zinc-500 group-hover:text-orange-400 transition-colors self-center" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M10.1 14c-1.5-1.5-1.4-4.06.3-5.77l4.8-4.86c1.72-1.74 4.3-1.83 5.8-.32 1.5 1.5 1.4 4.06-.3 5.78l-2.4 2.43" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M13.9 10c1.5 1.5 1.4 4.06-.3 5.77l-4.8 4.86c-1.72 1.74-4.3 1.83-5.8.32-1.5-1.5-1.4-4.06.3-5.78l2.4-2.43" />
            </svg>
            <%= bookmark.name %>
          </h3>
        </div>
        
        <a href="<%= bookmark.url %>" target="_blank" class="p-2.5 bg-zinc-800/70 backdrop-blur-sm text-zinc-300 hover:text-white hover:bg-zinc-700/80 rounded-xl transition-all active:scale-90 z-20">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
        </a>
      </div>
    </div>

    <!-- Description section -->
    <div class="flex items-end gap-1 relative">
      <p class="text-xs font-medium text-zinc-500 whitespace-nowrap truncate leading-tight">
        <% if bookmark.description.blank? %>
          No description
        <% else %>
          <%= bookmark.description %>
        <% end %>
      </p>
      <% unless bookmark.description.blank? %>
        <div data-controller="dropdown" class="flex flex-col justify-center group/info">
          <button data-action="dropdown#toggle" data-dropdown-target="button" >
            <svg class="w-4 h-4 text-zinc-500 group-hover/info:text-orange-400 transition-colors duration-200 cursor-pointer" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-label="Information">
              <circle cx="12" cy="12" r="10" stroke-width="2"/>
              <line x1="12" y1="16" x2="12" y2="12" stroke-width="2" stroke-linecap="round"/>
              <line x1="12" y1="8" x2="12" y2="8" stroke-width="2" stroke-linecap="round"/>
            </svg>
          </button>
          <p data-dropdown-target="list" class="hidden absolute top-[calc(100%+4px)] right-0 left-0 w-full text-sm text-zinc-300 bg-zinc-800 border border-zinc-700 rounded-2xl p-2 shadow-2xl z-50">
            <%= bookmark.description %>
          </p>
        </div>
      <% end %>
    </div>

    <% can_edit = bookmark.editable_by?(Current.user) %>
    <% is_collaborator = can_edit && Current.user.id != bookmark.user_id %>
    <div class="flex flex-col gap-2">
      <div class="flex flex-col gap-1.5 min-w-0">
        <% owner_tags = bookmark.tags.where(user_id: bookmark.user_id) %>

        <% if is_collaborator %>
          <% if owner_tags.any? %>
            <div class="flex flex-wrap items-center gap-2">
              <% owner_tags.each do |tag| %>
                <%= render "tags/bookmark_tag", bookmark: bookmark, tag: tag %>
              <% end %>
            </div>
          <% else %>
            <p class="text-xs text-zinc-600 italic">No owner tags</p>
          <% end %>
          <div class="h-px bg-zinc-800 my-1.5"></div>

          <div data-controller="dropdown" class="flex flex-wrap items-center gap-2 relative">
            <div class="flex flex-wrap items-center gap-2 opacity-80">
              <% bookmark.tags.where(user_id: Current.user.id).each do |tag| %>
                <%= render "tags/bookmark_tag", bookmark: bookmark, tag: tag %>
              <% end %>
            </div>
            <%= render "tags/add_tag_control", bookmark: bookmark %>

            <div data-controller="dropdown" class="flex items-center group/taginfo">
              <button type="button" data-action="dropdown#toggle" data-dropdown-target="button" class="text-zinc-600 hover:text-orange-400 transition-colors">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-label="How tags work">
                  <circle cx="12" cy="12" r="10" stroke-width="2"/>
                  <line x1="12" y1="16" x2="12" y2="12" stroke-width="2" stroke-linecap="round"/>
                  <line x1="12" y1="8" x2="12" y2="8" stroke-width="2" stroke-linecap="round"/>
                </svg>
              </button>
              <p data-dropdown-target="list" class="hidden absolute top-[calc(100%+4px)] right-0 w-56 text-xs text-zinc-300 bg-zinc-800 border border-zinc-700 rounded-2xl p-3 shadow-2xl z-50">
                Tags above the line belong to the folder owner and are visible to everyone. Tags below are your own — private, visible only to you.
              </p>
            </div>
          </div>
        <% else %>
          <div data-controller="dropdown" class="flex flex-wrap items-center gap-2 relative">
            <% owner_tags.each do |tag| %>
              <%= render "tags/bookmark_tag", bookmark: bookmark, tag: tag %>
            <% end %>
            <% if can_edit %>
              <%= render "tags/add_tag_control", bookmark: bookmark %>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
    <% if can_edit %>
      <div class="mt-auto flex gap-1 items-center justify-end">
        <%= link_to edit_bookmark_path(bookmark), data: { turbo_frame: 'modal' }, class: "p-2 text-zinc-500 hover:text-zinc-100 hover:bg-zinc-800 rounded-xl transition-all active:scale-90 cursor-pointer", title: "Edit" do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/></svg>
        <% end %>

        <%= button_to bookmark_path(bookmark), method: :delete, data: { turbo_confirm: "Are you sure about that?" }, class: "p-2 text-zinc-500 hover:text-red-400 hover:bg-red-500/10 rounded-xl transition-all active:scale-90 cursor-pointer" do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
