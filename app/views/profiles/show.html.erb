<div
  class="max-w-6xl w-11/12 mx-auto flex flex-col gap-10"
  data-controller="tabs"
  data-tabs-active-value="<%= @active_tab %>"
>
  <div class="space-y-2">
    <p class="text-xs font-semibold tracking-[0.2em] text-orange-400 uppercase">Account</p>
    <h1 class="text-3xl font-bold text-white">Profile</h1>
    <p class="text-sm text-zinc-500"><%= @user.email_address %></p>
  </div>

  <% if alert = flash[:alert] %>
    <div class="flex items-start gap-3 rounded-xl border border-red-500/30 bg-red-500/10 text-red-200 px-4 py-3 text-sm">
      <svg class="w-4 h-4 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M12 6.5a1.5 1.5 0 110 3 1.5 1.5 0 010-3z"/></svg>
      <span><%= alert %></span>
    </div>
  <% end %>

  <% if notice = flash[:notice] %>
    <div class="flex items-start gap-3 rounded-xl border border-emerald-500/30 bg-emerald-500/10 text-emerald-100 px-4 py-3 text-sm">
      <svg class="w-4 h-4 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
      <span><%= notice %></span>
    </div>
  <% end %>

  <nav class="flex gap-6 border-b border-zinc-800">
    <button
      type="button"
      data-tabs-target="tab"
      data-tab="stats"
      data-action="tabs#select"
      class="pb-3 text-sm font-semibold border-b-2 transition-colors cursor-pointer"
    >
      Stats
    </button>
    <button
      type="button"
      data-tabs-target="tab"
      data-tab="session"
      data-action="tabs#select"
      class="pb-3 text-sm font-semibold border-b-2 transition-colors cursor-pointer"
    >
      Session
    </button>
  </nav>

  <%= render "stats_tab" %>
  <%= render "session_tab" %>
</div>
