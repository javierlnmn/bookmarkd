<div data-tabs-target="panel" data-tab="stats" data-controller="delete-dialog" class="space-y-10 <%= 'hidden' unless @active_tab == 'stats' %>">
  <section class="space-y-4">
    <h2 class="text-lg font-bold text-white">Overview</h2>
    <div class="grid grid-cols-2 gap-6">
      <div>
        <p class="text-[10px] font-bold uppercase tracking-widest text-zinc-600">Folders</p>
        <p class="mt-1 text-3xl font-bold text-white"><%= @user.folders.count %></p>
      </div>
      <div>
        <p class="text-[10px] font-bold uppercase tracking-widest text-zinc-600">Bookmarks</p>
        <p class="mt-1 text-3xl font-bold text-white"><%= @user.bookmarks.count %></p>
      </div>
    </div>
  </section>

  <section class="space-y-4">
    <h2 class="text-lg font-bold text-white">Shared with me</h2>
    <div class="grid grid-cols-2 gap-6">
      <div>
        <p class="text-[10px] font-bold uppercase tracking-widest text-zinc-600">Folders</p>
        <p class="mt-1 text-3xl font-bold text-white"><%= @user.shared_folders_count %></p>
      </div>
      <div>
        <p class="text-[10px] font-bold uppercase tracking-widest text-zinc-600">Bookmarks</p>
        <p class="mt-1 text-3xl font-bold text-white"><%= @user.shared_bookmarks_count %></p>
      </div>
    </div>
  </section>

  <section class="space-y-4">
    <h2 class="text-lg font-bold text-white">Danger zone</h2>
    <p class="text-sm text-zinc-500">Permanently delete all your folders, bookmarks, and tags. Your account will stay active.</p>
    <button
      type="button"
      data-action="delete-dialog#open"
      class="cursor-pointer px-5 py-3 bg-red-500/10 hover:bg-red-500/20 text-red-400 hover:text-red-300 text-sm font-bold rounded-xl border border-red-500/20 transition-all active:scale-95"
    >
      Delete all data
    </button>
  </section>

  <dialog
    data-delete-dialog-target="dialog"
    class="bg-zinc-900 border border-zinc-800 p-6 rounded-2xl shadow-2xl backdrop:backdrop-blur-md backdrop:bg-black/80 max-w-sm w-11/12 fixed top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 m-0 open:flex flex-col"
  >
    <div class="flex flex-col gap-4 w-full">
      <h3 class="text-xl font-bold text-white">Delete all data?</h3>
      <p class="text-zinc-400 text-sm leading-relaxed">
        This will permanently delete all your folders, bookmarks, and tags. This action cannot be undone.
      </p>

      <%= form_with url: data_profile_path, method: :delete, class: "space-y-4" do |form| %>
        <div class="space-y-1.5">
          <%= form.label :password, "Confirm your password", class: "block text-[10px] font-bold uppercase tracking-widest text-zinc-600 ml-1" %>
          <%= form.password_field :password,
              required: true,
              autofocus: true,
              autocomplete: "current-password",
              name: "profile[password]",
              class: "w-full bg-zinc-900 border border-zinc-800 rounded-xl px-4 py-3 text-sm text-white placeholder:text-zinc-700 focus:outline-none focus:ring-2 focus:ring-red-500/10 focus:border-red-500/40 transition-all" %>
        </div>

        <div class="flex justify-end gap-3">
          <button
            type="button"
            data-action="delete-dialog#close"
            class="px-4 py-2 text-zinc-500 hover:text-zinc-300 text-sm font-semibold transition-colors cursor-pointer"
          >
            Cancel
          </button>
          <%= form.submit "Delete all data",
            class: "cursor-pointer px-5 py-2 bg-red-500 hover:bg-red-400 text-white text-sm font-bold rounded-xl transition-all active:scale-95" %>
        </div>
      <% end %>
    </div>
  </dialog>
</div>
